# PerfectTradingStrategy - Environment Configuration

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/perfecttrading

# Redis
REDIS_URL=redis://localhost:6379/0

# Binance Futures API
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true

# OKX Futures API
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_TESTNET=true

# JWT Authentication
JWT_SECRET=change-this-to-a-strong-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Risk Management
MAX_OPEN_POSITIONS=3
RISK_PER_TRADE=0.01
DAILY_LOSS_LIMIT=0.03
WEEKLY_LOSS_LIMIT=0.08
MIN_RISK_REWARD=3.0

# Scanner
SCANNER_SCAN_INTERVAL=60

# Debug
DEBUG=false
